      "boundElements": null,
      "updated": 1783463325962,
      "link": null,
      "locked": false,
      "text": "Services\n1. airport-outlet-service : Manages all airport stores related\ninformation\n2. user-service: Manages all user related information like user\nflight bookings, preferences, etc\n3. user-auth-service: Authenticates the user\n4. keywords-embedding-service: Creates embedding for the\nkeywords and stores them in vectorDB\n",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "r_raHGaevDnknRZIV8ll_",
      "originalText": "Services\n1. airport-outlet-service : Manages all airport stores related information\n2. user-service: Manages all user related information like user flight bookings, preferences, etc\n3. user-auth-service: Authenticates the user\n4. keywords-embedding-service: Creates embedding for the keywords and stores them in vectorDB\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
