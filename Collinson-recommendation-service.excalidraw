      "boundElements": [],
      "updated": 1783275225406,
      "link": null,
      "locked": false,
      "text": "Functional requirements\n1. Users should be able to create/update/delete document\n2. Users should be able to edit the document collaboratively\n3. Users should be able to view doc if readonly\n\n\nNon- functionals:\n1. Millions of doc\n2. <=100 concurrent edits\n3. Consistency(Eventual) : Resolve conflicts\n4. Latency must be low",
      "fontSize": 19.100050649174186,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional requirements\n1. Users should be able to create/update/delete document\n2. Users should be able to edit the document collaboratively\n3. Users should be able to view doc if readonly\n\n\nNon- functionals:\n1. Millions of doc\n2. <=100 concurrent edits\n3. Consistency(Eventual) : Resolve conflicts\n4. Latency must be low",
      "autoResize": false,
      "lineHeight": 1.25
    },
